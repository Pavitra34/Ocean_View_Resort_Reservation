<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <welcome-file-list>
        <welcome-file>auth/login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.oceanview.controller.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.oceanview.controller.RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>
    
    <servlet>
    <servlet-name>AddReceptionistServlet</servlet-name>
    <servlet-class>com.oceanview.controller.AddReceptionistServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AddReceptionistServlet</servlet-name>
    <url-pattern>/AddReceptionistServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>AddReservationServlet</servlet-name>
    <servlet-class>com.oceanview.controller.AddReservationServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AddReservationServlet</servlet-name>
    <url-pattern>/AddReservationServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>AddRoomServlet</servlet-name>
    <servlet-class>com.oceanview.controller.AddRoomServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AddRoomServlet</servlet-name>
    <url-pattern>/AddRoomServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.oceanview.controller.LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/LogoutServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>ViewReceptionistsServlet</servlet-name>
    <servlet-class>com.oceanview.controller.ViewReceptionistsServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ViewReceptionistsServlet</servlet-name>
    <url-pattern>/ViewReceptionistsServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>DeleteStaffServlet</servlet-name>
    <servlet-class>com.oceanview.controller.DeleteStaffServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteStaffServlet</servlet-name>
    <url-pattern>/DeleteStaffServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>UpdateStaffServlet</servlet-name>
    <servlet-class>com.oceanview.controller.UpdateStaffServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>UpdateStaffServlet</servlet-name>
    <url-pattern>/UpdateStaffServlet</url-pattern>
</servlet-mapping>

</web-app>